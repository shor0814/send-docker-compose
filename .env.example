# ═══════════════════════════════════════════════════════════════════════════════
#  Send — Docker Compose Configuration
#  Copy this file to .env and fill in your values.
#  .env is excluded from version control (.gitignore).
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Docker Image ─────────────────────────────────────────────────────────────
# Latest Send version by @timvisee:
DOCKER_SEND_IMAGE=ghcr.io/shor0814/send:latest
# Upstream unmodified version by @timvisee:
# DOCKER_SEND_IMAGE=registry.gitlab.com/timvisee/send:latest
# Outdated (archived) Mozilla version:
# DOCKER_SEND_IMAGE=mozilla/send:latest

DETECT_WEBSOCKET_PORT=false

# ─── Host & URLs ──────────────────────────────────────────────────────────────
HOST=send.example.com
SEND_BASE_URL=https://send.example.com

# ─── LetsEncrypt SSL (used by nginx-proxy companion) ──────────────────────────
# Must match HOST
LETSENCRYPT_HOST=send.example.com
LETSENCRYPT_EMAIL=admin@example.com

# ─── Site Identity ────────────────────────────────────────────────────────────
CUSTOM_TITLE=Example Company Send
CUSTOM_DESCRIPTION=Secure, ephemeral file sharing for our clients.
CUSTOM_FOOTER_TEXT=Powered by Example Company

# Path to a custom icon/logo inside the custom_assets/ directory
UI_CUSTOM_ASSETS_ICON=custom_assets/logo.png

# ─── Brand Colors (Hex codes) ─────────────────────────────────────────────────
# Primary action color (buttons, links, highlights)
UI_COLOR_PRIMARY=#CB2910
# Accent / hover color
UI_COLOR_ACCENT=#FF826F
# Path to additional CSS overrides inside the custom_assets/ directory
UI_CUSTOM_CSS=custom_assets/brand.css

# ─── Footer & Legal Links ─────────────────────────────────────────────────────
# Main site footer link
UI_FOOTER_URL=https://example.com
CUSTOM_FOOTER_URL=https://example.com

# Privacy and terms pages
UI_PRIVACY_URL=https://example.com/privacy
CUSTOM_PRIVACY_URL=https://example.com/privacy
UI_TERMS_URL=https://example.com/terms
CUSTOM_TERMS_URL=https://example.com/terms

# Footer icon links — leave blank to hide
SEND_FOOTER_CLI_URL=https://github.com/timvisee/ffsend
SEND_FOOTER_DMCA_URL=https://example.com/dmca
SEND_FOOTER_DONATE_URL=
SEND_FOOTER_SOURCE_URL=https://github.com/shor0814/send

# ─── UI Options ───────────────────────────────────────────────────────────────
SHOW_THUNDERBIRD_SPONSOR=false

# ─── Upload Limits ────────────────────────────────────────────────────────────
# Uncomment and adjust to override defaults
# EXPIRE_TIMES_SECONDS=3600,86400,604800,2592000,31536000
# DEFAULT_EXPIRE_SECONDS=3600
# MAX_EXPIRE_SECONDS=31536000
# DOWNLOAD_COUNTS=1,2,5,10,15,25,50,100,1000
# MAX_DOWNLOADS=1000
# MAX_FILE_SIZE=2684354560

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by Prisma for the tbpro-compatible schema (user accounts, file ownership)
# The postgres service name in docker-compose is the hostname inside the network
POSTGRES_USER=send
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=send
DATABASE_URL=postgresql://send:your_strong_password_here@postgres:5432/send

# ─── Storage ──────────────────────────────────────────────────────────────────
# Option A: Local filesystem storage
# Uncomment FILE_DIR and comment out the S3 block below.
# Also uncomment the ./uploads:/uploads volume in docker-compose.yaml.
# FILE_DIR=/uploads

# Option B: S3-compatible object storage (default)
AWS_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_S3_SECRET_ACCESS_KEY
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://s3.example.com
# Set to true for non-AWS providers (MinIO, Ceph, etc.)
S3_USE_PATH_STYLE_ENDPOINT=true
